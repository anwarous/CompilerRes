procedure saisie(@n : entier)
debut
    repeter
        Ecrire("donner n : ")
        Lire(n)
    jusqu'a n > 0
fin

fonction sommeChiffre(n : entier) : entier
debut
    s <-- 0
    tant que n != 0 faire
        s <-- s + n MOD 10
        n <-- n DIV 10
    fin tant que
    retourner s
fin

Algorithme ex11
debut
    saisie(n)
    s <-- sommeChiffre(n)
    Ecrire(s)
fin
