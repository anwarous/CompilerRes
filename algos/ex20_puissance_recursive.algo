fonction puiss(base : entier, exp : entier) : entier
debut
    si exp = 0 alors
        retourner 1
    sinon
        retourner base * puiss(base, exp - 1)
    fin si
fin

Algorithme ex20
debut
    Ecrire("Donner la base : ")
    Lire(base)
    Ecrire("Donner l'exposant : ")
    Lire(exp)
    Ecrire(base, "^", exp, " = ", puiss(base, exp))
fin
