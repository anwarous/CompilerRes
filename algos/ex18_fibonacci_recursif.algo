fonction fib(n : entier) : entier
debut
    si n <= 0 alors
        retourner 0
    sinon
        si n = 1 alors
            retourner 1
        sinon
            retourner fib(n-1) + fib(n-2)
        fin si
    fin si
fin

Algorithme ex18
debut
    Ecrire("Donner n : ")
    Lire(n)
    pour i de 0 a n faire
        Ecrire("fib(", i, ") = ", fib(i))
    fin pour
fin
